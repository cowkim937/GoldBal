{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "goldbalance",
  "main": "dist/index.html",
  "compatibility_date": "2026-06-20",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
