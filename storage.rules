rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /game-thumbnails/{gameId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /games/{gameId}/{cellId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
